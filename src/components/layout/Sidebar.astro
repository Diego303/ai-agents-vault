---
/**
 * Sidebar.astro
 * Left sidebar with vault title, search trigger, and folder tree.
 */
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const base = import.meta.env.BASE_URL;

// Get all vault notes and organize by folder
const allNotes = await getCollection('vault');

interface FolderNode {
  name: string;
  path: string;
  children: FolderNode[];
  notes: { slug: string; title: string }[];
}

function buildFolderTree(notes: typeof allNotes): FolderNode {
  const root: FolderNode = { name: 'root', path: '', children: [], notes: [] };

  for (const note of notes) {
    const parts = note.id.split('/');
    let current = root;

    // Navigate to or create folder nodes
    for (let i = 0; i < parts.length - 1; i++) {
      const folderName = parts[i];
      let child = current.children.find(c => c.name === folderName);
      if (!child) {
        child = { name: folderName, path: parts.slice(0, i + 1).join('/'), children: [], notes: [] };
        current.children.push(child);
      }
      current = child;
    }

    // Add note to the current folder
    const filename = parts[parts.length - 1].replace(/\.md$/, '');
    const title = note.data.title || filename.replace(/-/g, ' ');
    current.notes.push({ slug: note.id, title });
  }

  // Sort folders alphabetically, notes alphabetically
  function sortTree(node: FolderNode) {
    node.children.sort((a, b) => a.name.localeCompare(b.name));
    node.notes.sort((a, b) => a.title.localeCompare(b.title));
    node.children.forEach(sortTree);
  }
  sortTree(root);

  return root;
}

const tree = buildFolderTree(allNotes);

// Determine which folders should be expanded (ancestors of current note)
const currentParts = currentSlug.split('/');
const expandedPaths = new Set<string>();
for (let i = 1; i <= currentParts.length - 1; i++) {
  expandedPaths.add(currentParts.slice(0, i).join('/'));
}
---

<div class="sidebar-inner">
  <!-- Vault header -->
  <div class="sidebar-header">
    <a href={base} class="vault-title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z"/>
        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
        <line x1="12" y1="22.08" x2="12" y2="12"/>
      </svg>
      <span>Segundo Cerebro</span>
    </a>
  </div>

  <!-- Search trigger -->
  <div class="sidebar-search">
    <button class="search-trigger" id="search-trigger">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <span>Buscar...</span>
      <kbd>⌘K</kbd>
    </button>
  </div>

  <!-- Folder tree -->
  <nav class="folder-tree" aria-label="Navegación del vault">
    {tree.children.map(folder => (
      <div class="folder-group">
        <details open={expandedPaths.has(folder.path)}>
          <summary class="folder-name">
            <svg class="folder-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
            <svg class="folder-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/>
            </svg>
            <span>{folder.name}</span>
          </summary>
          <div class="folder-contents">
            {/* Sub-folders */}
            {folder.children.map(sub => (
              <details class="subfolder" open={expandedPaths.has(sub.path)}>
                <summary class="folder-name subfolder-name">
                  <svg class="folder-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                  </svg>
                  <span>{sub.name}</span>
                </summary>
                <div class="folder-contents">
                  {sub.notes.map(note => (
                    <a
                      href={`${base}${note.slug}/`}
                      class:list={['note-link', { active: note.slug === currentSlug }]}
                    >
                      {note.title}
                    </a>
                  ))}
                </div>
              </details>
            ))}
            {/* Notes in this folder */}
            {folder.notes.map(note => (
              <a
                href={`${base}${note.slug}/`}
                class:list={['note-link', { active: note.slug === currentSlug }]}
              >
                {note.title}
              </a>
            ))}
          </div>
        </details>
      </div>
    ))}
    {/* Root-level notes (if any) */}
    {tree.notes.map(note => (
      <a
        href={`${base}${note.slug}/`}
        class:list={['note-link root-note', { active: note.slug === currentSlug }]}
      >
        {note.title}
      </a>
    ))}
  </nav>
</div>

<style>
  .sidebar-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* ─── Header ─────────────────────────────────────────────────── */
  .sidebar-header {
    padding: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  .vault-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-main);
    text-decoration: none;
  }

  .vault-title svg {
    color: var(--link-color);
    flex-shrink: 0;
  }

  /* ─── Search ─────────────────────────────────────────────────── */
  .sidebar-search {
    padding: 0.75rem;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem 0.75rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 0.375rem;
    color: var(--text-muted);
    font-family: var(--font-ui);
    font-size: 0.8rem;
    cursor: pointer;
    transition: border-color 200ms ease;
  }

  .search-trigger:hover {
    border-color: var(--link-color);
  }

  .search-trigger span {
    flex: 1;
    text-align: left;
  }

  .search-trigger kbd {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    padding: 0.1rem 0.35rem;
    border: 1px solid var(--border-color);
    border-radius: 0.2rem;
    color: var(--text-muted);
    background: var(--bg-main);
  }

  /* ─── Folder tree ────────────────────────────────────────────── */
  .folder-tree {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 0.75rem 1rem;
    font-family: var(--font-ui);
    font-size: 0.8rem;
  }

  .folder-group {
    margin-bottom: 0.25rem;
  }

  details {
    border: none;
    margin: 0;
  }

  details > summary {
    border: none;
    padding: 0;
  }

  .folder-name {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.5rem;
    border-radius: 0.25rem;
    cursor: pointer;
    color: var(--text-main);
    font-weight: 500;
    user-select: none;
    list-style: none;
    transition: background-color 150ms ease;
  }

  .folder-name::-webkit-details-marker {
    display: none;
  }

  .folder-name::marker {
    content: '';
    display: none;
  }

  .folder-name:hover {
    background: var(--sidebar-hover);
  }

  .folder-chevron {
    flex-shrink: 0;
    transition: transform 200ms ease;
    color: var(--text-muted);
  }

  details[open] > .folder-name .folder-chevron {
    transform: rotate(90deg);
  }

  .folder-icon {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .subfolder-name {
    font-size: 0.78rem;
    padding: 0.3rem 0.5rem;
  }

  .folder-contents {
    padding-left: 1rem;
    border-left: 1px solid var(--border-color);
    margin-left: 0.75rem;
    margin-top: 0.15rem;
  }

  /* ─── Note links ─────────────────────────────────────────────── */
  .note-link {
    display: block;
    padding: 0.3rem 0.5rem;
    border-radius: 0.25rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.78rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: background-color 150ms ease, color 150ms ease;
  }

  .note-link:hover {
    background: var(--sidebar-hover);
    color: var(--text-main);
  }

  .note-link.active {
    background: var(--sidebar-hover);
    color: var(--link-color);
    font-weight: 500;
  }

  .root-note {
    padding-left: 0.5rem;
  }
</style>

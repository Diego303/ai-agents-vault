---
/**
 * Backlinks.astro
 * Shows which notes link to the current note.
 */
import type { BacklinkEntry } from '../../utils/backlinks';

interface Props {
  backlinks: BacklinkEntry[];
}

const { backlinks } = Astro.props;
const base = import.meta.env.BASE_URL;
---

{backlinks.length > 0 && (
  <div class="backlinks">
    <div class="backlinks-header">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 17H7A5 5 0 017 7h2"/>
        <path d="M15 7h2a5 5 0 010 10h-2"/>
        <line x1="8" y1="12" x2="16" y2="12"/>
      </svg>
      <span>Backlinks ({backlinks.length})</span>
    </div>
    <ul class="backlinks-list">
      {backlinks.map(bl => (
        <li>
          <a href={`${base}${bl.slug}/`} class="backlink-item">
            <span class="backlink-title">{bl.title}</span>
            {bl.context && <span class="backlink-context">{bl.context}</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>
)}

<style>
  .backlinks {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    font-family: var(--font-ui);
  }

  .backlinks-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .backlinks-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .backlinks-list li {
    margin-bottom: 0.35rem;
  }

  .backlink-item {
    display: block;
    padding: 0.4rem 0.6rem;
    border-radius: 0.25rem;
    text-decoration: none;
    transition: background-color 150ms ease;
  }

  .backlink-item:hover {
    background: var(--sidebar-hover);
  }

  .backlink-title {
    display: block;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--link-color);
    line-height: 1.3;
  }

  .backlink-context {
    display: block;
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.4;
    margin-top: 0.15rem;
  }
</style>

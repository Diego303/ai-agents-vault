---
/**
 * BaseLayout.astro
 * HTML base with fonts, meta tags, CSS, and theme detection.
 */
import '../styles/global.css';
import '../styles/callouts.css';
import '../styles/markdown.css';
import '../styles/animations.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Base de conocimiento sobre IA y agentes' } = Astro.props;
const siteTitle = 'Segundo Cerebro — IA & Agentes';
const fullTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://Diego303.github.io/ai-agents-vault/');

// JSON-LD structured data
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title || siteTitle,
  description,
  url: canonicalURL.href,
  publisher: {
    '@type': 'Organization',
    name: 'Segundo Cerebro',
  },
});
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />

    <title>{fullTitle}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />

    <!-- Google Fonts: Playfair Display, Literata, Inter, Fira Code -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@400;500;600;700&family=Literata:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <!-- KaTeX CSS for LaTeX math rendering -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      crossorigin="anonymous"
    />

    <!-- Theme detection: runs before paint to avoid flash -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

  </head>
  <body>
    <slot />
  </body>
</html>

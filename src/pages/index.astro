---
/**
 * index.astro
 * Splash / welcome page — minimal, centered, leads to /docs.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Inicio" description="Base de conocimiento exhaustiva sobre inteligencia artificial, agentes de IA y el ecosistema de herramientas propias.">
  <div class="splash">
    <!-- Brain icon -->
    <div class="splash-icon">
      <svg width="64" height="64" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="M50 8C38 8 30 14 26 22C18 22 12 30 12 40C12 48 16 54 22 58C22 66 28 72 36 74L36 80C36 84 40 86 44 86L56 86C60 86 64 84 64 80L64 74C72 72 78 66 78 58C84 54 88 48 88 40C88 30 82 22 74 22C70 14 62 8 50 8Z" stroke-width="3.5"/>
        <path d="M50 14V78" stroke-width="1.5" opacity="0.45"/>
        <path d="M28 32C36 34 42 40 46 48" stroke-width="2.5" opacity="0.45"/>
        <path d="M24 50C32 48 40 52 46 60" stroke-width="2.5" opacity="0.35"/>
        <path d="M72 32C64 34 58 40 54 48" stroke-width="2.5" opacity="0.45"/>
        <path d="M76 50C68 48 60 52 54 60" stroke-width="2.5" opacity="0.35"/>
      </svg>
    </div>

    <!-- Title -->
    <h1 class="splash-title">Segundo Cerebro</h1>
    <p class="splash-subtitle">IA & Agentes</p>

    <!-- Description -->
    <p class="splash-desc">
      Base de conocimiento exhaustiva sobre inteligencia artificial, agentes de IA, y el ecosistema de herramientas propias — <em>intake</em>, <em>architect</em>, <em>vigil</em>, <em>licit</em>. Centro de referencia para investigación, desarrollo y toma de decisiones.
    </p>

    <!-- CTA -->
    <a href={`${base}docs/`} class="splash-cta">
      Ir a la documentación
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>

    <!-- Theme toggle -->
    <button class="splash-theme" id="splash-theme" aria-label="Cambiar tema">
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
      </svg>
    </button>
  </div>
</BaseLayout>

<style>
  .splash {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
    position: relative;
  }

  /* ─── Brain icon ─────────────────────────────────────────────── */
  .splash-icon {
    color: var(--link-color);
    margin-bottom: 1.75rem;
    opacity: 0.85;
  }

  /* ─── Title ──────────────────────────────────────────────────── */
  .splash-title {
    font-family: var(--font-display);
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.35rem;
    letter-spacing: -0.02em;
  }

  .splash-subtitle {
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 500;
    color: var(--link-color);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
  }

  /* ─── Description ────────────────────────────────────────────── */
  .splash-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-muted);
    max-width: 520px;
    margin-bottom: 2.5rem;
  }

  .splash-desc em {
    color: var(--text-main);
    font-style: normal;
    font-weight: 500;
  }

  /* ─── CTA Button ─────────────────────────────────────────────── */
  .splash-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.75rem;
    background: var(--link-color);
    color: #fff;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 0.5rem;
    transition: opacity 200ms ease, transform 200ms ease;
  }

  .splash-cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .splash-cta:active {
    transform: translateY(0);
  }

  /* ─── Theme toggle ───────────────────────────────────────────── */
  .splash-theme {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: 1px solid var(--border-color);
    border-radius: 0.375rem;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.4rem;
    display: flex;
    align-items: center;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .splash-theme:hover {
    color: var(--link-color);
    border-color: var(--link-color);
  }

  .icon-sun { display: none; }
  .icon-moon { display: block; }
  html.dark .icon-sun { display: block; }
  html.dark .icon-moon { display: none; }

  /* ─── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .splash { padding: 1.5rem; }
    .splash-icon svg { width: 48px; height: 48px; }
    .splash-title { font-size: 2rem; }
    .splash-subtitle { font-size: 0.85rem; letter-spacing: 0.1em; margin-bottom: 1.5rem; }
    .splash-desc { font-size: 0.9rem; margin-bottom: 2rem; }
    .splash-cta { padding: 0.6rem 1.25rem; font-size: 0.85rem; }
    .splash-theme { top: 1rem; right: 1rem; }
  }

  @media (min-width: 640px) {
    .splash-title { font-size: 3.25rem; }
  }
</style>

<script>
  document.getElementById('splash-theme')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>

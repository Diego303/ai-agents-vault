---
/**
 * [tag].astro
 * Lists all notes with a specific tag.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allNotes = await getCollection('vault');
  const tagSet = new Set<string>();
  allNotes.forEach(note => note.data.tags?.forEach((t: string) => tagSet.add(t)));

  return Array.from(tagSet).map(tag => ({
    params: { tag },
    props: {
      tag,
      notes: allNotes.filter(n => n.data.tags?.includes(tag)),
    },
  }));
}

const { tag, notes } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`#${tag}`}>
  <div class="tag-page">
    <header class="tag-header">
      <a href={base} class="back-link">&larr; Inicio</a>
      <h1 class="tag-title">#{tag}</h1>
      <p class="tag-count">{notes.length} {notes.length === 1 ? 'nota' : 'notas'}</p>
    </header>
    <ul class="note-list">
      {notes.map((note: any) => {
        const slug = note.id.replace(/\.md$/, '');
        const title = note.data.title || slug.split('/').pop()?.replace(/-/g, ' ') || slug;
        return (
          <li>
            <a href={`${base}${slug}/`} class="note-item">
              <span class="note-title">{title}</span>
              <span class="note-folder">{slug.split('/')[0]}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</BaseLayout>

<style>
  .tag-page {
    max-width: 700px;
    margin: 0 auto;
    padding: 3rem 2rem;
    font-family: var(--font-ui);
  }

  .back-link {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .back-link:hover { color: var(--link-color); }

  .tag-title {
    font-family: var(--font-display);
    font-size: 2rem;
    margin: 0.5rem 0 0.25rem;
  }

  .tag-count {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 2rem;
  }

  .note-list {
    list-style: none;
    padding: 0;
  }

  .note-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: 0.375rem;
    margin-bottom: 0.5rem;
    text-decoration: none;
    transition: border-color 200ms ease;
  }

  .note-item:hover { border-color: var(--link-color); }

  .note-title {
    color: var(--text-main);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .note-folder {
    color: var(--text-muted);
    font-size: 0.72rem;
  }
</style>

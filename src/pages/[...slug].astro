---
/**
 * [...slug].astro
 * Dynamic route for all vault notes.
 * Renders each markdown note with NoteLayout.
 */
import { getCollection, render } from 'astro:content';
import NoteLayout from '../layouts/NoteLayout.astro';
import { resolveTitle } from '../utils/frontmatter';

export async function getStaticPaths() {
  const notes = await getCollection('vault');
  return notes.map(note => {
    // The id from glob loader may include .md extension
    const slug = note.id.replace(/\.md$/, '');
    return {
      params: { slug },
      props: { note },
    };
  });
}

const { note } = Astro.props;
const { Content, headings } = await render(note);

const slug = note.id.replace(/\.md$/, '');
const filename = slug.split('/').pop() || slug;
const title = resolveTitle(note.data.title, note.body || '', filename);

// Extract description from first paragraph or abstract callout
let description = '';
if (note.body) {
  // Try to find abstract callout content
  const abstractMatch = note.body.match(/>\s*\[!abstract\][\s\S]*?\n(?:>\s*.+\n)*/);
  if (abstractMatch) {
    description = abstractMatch[0]
      .replace(/>\s*\[!abstract\][^\n]*/,'')
      .replace(/>\s*/g, '')
      .replace(/[=*[\]#]/g, '')
      .trim()
      .slice(0, 160);
  }
  if (!description) {
    // Fallback: first non-heading, non-empty paragraph
    const lines = note.body.split('\n');
    for (const line of lines) {
      const trimmed = line.trim();
      if (trimmed && !trimmed.startsWith('#') && !trimmed.startsWith('>') && !trimmed.startsWith('---')) {
        description = trimmed.replace(/[=*[\]#]/g, '').slice(0, 160);
        break;
      }
    }
  }
}
---

<NoteLayout
  title={title}
  description={description}
  frontmatter={note.data}
  headings={headings}
  currentSlug={slug}
>
  <Content />
</NoteLayout>

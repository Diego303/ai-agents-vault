---
/**
 * index.astro
 * Landing page — Hero, vault stats, MOC sections with cards, ecosystem badges.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchModal from '../components/search/SearchModal.astro';
import { getCollection } from 'astro:content';
import { getMOCsBySection } from '../utils/moc-mapping';

const base = import.meta.env.BASE_URL;
const allNotes = await getCollection('vault');

// Resolve resource slugs from actual collection IDs (case-insensitive)
function findSlug(name: string): string {
  const lower = name.toLowerCase();
  const note = allNotes.find(n => {
    const id = n.id.replace(/\.md$/, '').toLowerCase();
    return id.endsWith(lower);
  });
  return note ? note.id.replace(/\.md$/, '') : `_meta/${name}`;
}
const taxonomiaSlug = findSlug('taxonomia');
const glosarioSlug = findSlug('glosario');


// Stats
const totalNotes = allNotes.length;
const allTags = new Set<string>();
allNotes.forEach(n => n.data.tags?.forEach((t: string) => allTags.add(t)));

// Count notes per folder for MOC cards
const folderCounts = new Map<string, number>();
for (const note of allNotes) {
  const folder = note.id.split('/')[0] || '';
  folderCounts.set(folder, (folderCounts.get(folder) || 0) + 1);
}

// MOC sections
const mocSections = getMOCsBySection();

// Ecosystem tools
const ecosystemTools = [
  { name: 'Architect', abbr: 'Ar', lightBg: '#dbeafe', lightText: '#1d4ed8', darkBg: 'rgba(30,64,175,0.3)', darkText: '#60a5fa', darkBorder: 'rgba(30,64,175,0.5)' },
  { name: 'Vigil', abbr: 'Vi', lightBg: '#fee2e2', lightText: '#b91c1c', darkBg: 'rgba(185,28,28,0.3)', darkText: '#f87171', darkBorder: 'rgba(185,28,28,0.5)' },
  { name: 'Licit', abbr: 'Li', lightBg: '#dcfce7', lightText: '#15803d', darkBg: 'rgba(21,128,61,0.3)', darkText: '#4ade80', darkBorder: 'rgba(21,128,61,0.5)' },
  { name: 'Intake', abbr: 'In', lightBg: '#f3e8ff', lightText: '#7e22ce', darkBg: 'rgba(126,34,206,0.3)', darkText: '#c084fc', darkBorder: 'rgba(126,34,206,0.5)' },
];
---

<BaseLayout title="Inicio">
  <div class="landing">
    <!-- Header -->
    <header class="landing-header">
      <div class="header-inner">
        <div class="header-left">
          <svg width="24" height="24" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M50 8C38 8 30 14 26 22C18 22 12 30 12 40C12 48 16 54 22 58C22 66 28 72 36 74L36 80C36 84 40 86 44 86L56 86C60 86 64 84 64 80L64 74C72 72 78 66 78 58C84 54 88 48 88 40C88 30 82 22 74 22C70 14 62 8 50 8Z" stroke-width="5"/>
            <path d="M50 14V78" stroke-width="2" opacity="0.5"/>
            <path d="M28 32C36 34 42 40 46 48" stroke-width="3" opacity="0.5"/>
            <path d="M24 50C32 48 40 52 46 60" stroke-width="3" opacity="0.4"/>
            <path d="M72 32C64 34 58 40 54 48" stroke-width="3" opacity="0.5"/>
            <path d="M76 50C68 48 60 52 54 60" stroke-width="3" opacity="0.4"/>
          </svg>
          <h1>Segundo Cerebro</h1>
        </div>
        <div class="header-actions">
          <button class="search-btn" id="landing-search-btn" aria-label="Buscar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>Buscar</span>
            <kbd>⌘K</kbd>
          </button>
          <button class="theme-toggle-landing" id="theme-toggle-landing" aria-label="Cambiar tema">
            <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero">
      <h2 class="hero-title">IA & Agentes</h2>
      <p class="hero-subtitle">
        Base de conocimiento exhaustiva sobre inteligencia artificial, agentes de IA, y el ecosistema de herramientas propias.
        <span class="hero-highlight">Centro de referencia para investigación, desarrollo, y toma de decisiones.</span>
      </p>
      <div class="hero-stats">
        <div class="stat"><span class="stat-number">{totalNotes}</span><span class="stat-label">Notas</span></div>
        <div class="stat"><span class="stat-number">{allTags.size}</span><span class="stat-label">Tags</span></div>
        <div class="stat"><span class="stat-number">{mocSections.size}</span><span class="stat-label">Secciones</span></div>
      </div>
    </section>

    <!-- MOC Sections -->
    <section class="moc-sections">
      {Array.from(mocSections.entries()).map(([sectionName, mocs]) => (
        <div class="moc-section">
          <h3 class="section-title">{sectionName}</h3>
          <div class="section-grid">
            {mocs.map(moc => {
              const count = folderCounts.get(moc.folder) || 0;
              return (
                <a href={`${base}${moc.slug}/`} class="moc-card">
                  <div class="moc-card-title">{moc.title}</div>
                  <div class="moc-card-desc">{moc.description}</div>
                  <div class="moc-card-count">{count} notas</div>
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </section>

    <!-- Ecosystem badges -->
    <section class="ecosystem">
      <h3 class="section-title">Ecosistema propio</h3>
      <div class="ecosystem-grid">
        {ecosystemTools.map(tool => (
          <div class="eco-badge" style={`--eco-light-bg: ${tool.lightBg}; --eco-light-text: ${tool.lightText}; --eco-dark-bg: ${tool.darkBg}; --eco-dark-text: ${tool.darkText}; --eco-dark-border: ${tool.darkBorder};`}>
            <span class="eco-abbr">{tool.abbr}</span>
            <span class="eco-name">{tool.name}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Resources -->
    <section class="resources">
      <h3 class="section-title">Recursos transversales</h3>
      <div class="resources-grid">
        <a href={`${base}${taxonomiaSlug}/`} class="resource-link">Sistema de tags y categorías</a>
        <a href={`${base}${glosarioSlug}/`} class="resource-link">Glosario maestro A-Z</a>
        <a href={`${base}tags/`} class="resource-link">Explorar por tags</a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="landing-footer">
      <p>Generado con Astro desde un vault de Obsidian</p>
    </footer>
  </div>

  <SearchModal />
</BaseLayout>

<style>
  .landing { min-height: 100vh; font-family: var(--font-ui); }

  /* Header */
  .landing-header { border-bottom: 1px solid var(--border-color); padding: 0.75rem 2rem; }
  .header-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
  .header-left { display: flex; align-items: center; gap: 0.75rem; }
  .header-left svg { color: var(--link-color); }
  .header-left h1 { font-family: var(--font-ui); font-size: 1.1rem; font-weight: 600; margin: 0; }
  .header-actions { display: flex; align-items: center; gap: 0.5rem; }

  .search-btn {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 0.375rem;
    color: var(--text-muted); font-family: var(--font-ui); font-size: 0.78rem; cursor: pointer;
    transition: border-color 200ms ease;
  }
  .search-btn:hover { border-color: var(--link-color); }
  .search-btn kbd { font-size: 0.6rem; padding: 0.1rem 0.3rem; border: 1px solid var(--border-color); border-radius: 0.2rem; background: var(--bg-main); }
  .search-btn span { display: none; }
  @media (min-width: 640px) { .search-btn span { display: inline; } }

  .theme-toggle-landing { background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 0.35rem; border-radius: 0.25rem; }
  .theme-toggle-landing:hover { color: var(--link-color); }
  .icon-sun { display: none; } .icon-moon { display: block; }
  html.dark .icon-sun { display: block; } html.dark .icon-moon { display: none; }

  /* Hero */
  .hero { text-align: center; padding: 3.5rem 2rem 2.5rem; max-width: 700px; margin: 0 auto; }
  .hero-title { font-family: var(--font-display); font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; }
  .hero-subtitle { font-family: var(--font-body); font-size: 1rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 2rem; }
  .hero-highlight { color: var(--text-main); font-weight: 500; }
  .hero-stats { display: flex; justify-content: center; gap: 3rem; }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat-number { font-size: 1.75rem; font-weight: 700; color: var(--link-color); }
  .stat-label { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }

  /* MOC Sections */
  .moc-sections { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
  .moc-section { margin-bottom: 2rem; }
  .section-title {
    font-family: var(--font-ui); font-size: 0.78rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted);
    margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color);
  }
  .section-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 0.65rem; }

  .moc-card {
    display: block; padding: 0.85rem 1rem;
    background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 0.5rem;
    text-decoration: none; transition: border-color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
  }
  .moc-card:hover { border-color: var(--link-color); box-shadow: 0 2px 8px rgba(0,0,0,0.05); transform: translateY(-1px); }
  html.dark .moc-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.2); }
  .moc-card-title { font-size: 0.88rem; font-weight: 600; color: var(--text-main); margin-bottom: 0.2rem; }
  .moc-card-desc { font-size: 0.75rem; color: var(--text-muted); line-height: 1.4; margin-bottom: 0.35rem; }
  .moc-card-count { font-size: 0.68rem; color: var(--text-muted); opacity: 0.7; }

  /* Ecosystem */
  .ecosystem { max-width: 1100px; margin: 0 auto; padding: 0.5rem 2rem 1.5rem; }
  .ecosystem-grid { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .eco-badge {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 1rem; border-radius: 9999px;
    background: var(--eco-light-bg); color: var(--eco-light-text);
    font-size: 0.8rem; font-weight: 500;
  }
  html.dark .eco-badge { background: var(--eco-dark-bg); color: var(--eco-dark-text); border: 1px solid var(--eco-dark-border); }
  .eco-abbr { font-weight: 700; font-size: 0.7rem; }

  /* Resources */
  .resources { max-width: 1100px; margin: 0 auto; padding: 0.5rem 2rem 2rem; }
  .resources-grid { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .resource-link {
    padding: 0.5rem 1rem;
    background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 0.375rem;
    color: var(--text-main); text-decoration: none; font-size: 0.82rem;
    transition: border-color 200ms ease;
  }
  .resource-link:hover { border-color: var(--link-color); }

  /* Footer */
  .landing-footer {
    text-align: center; padding: 2rem; border-top: 1px solid var(--border-color);
    color: var(--text-muted); font-size: 0.72rem;
  }

  /* Mobile (≤ 600px) */
  @media (max-width: 600px) {
    .landing-header { padding: 0.6rem 1rem; }
    .header-left h1 { font-size: 0.95rem; }
    .hero { padding: 2rem 1rem 1.5rem; }
    .hero-title { font-size: 1.75rem; }
    .hero-subtitle { font-size: 0.9rem; margin-bottom: 1.25rem; }
    .hero-stats { gap: 1.5rem; }
    .stat-number { font-size: 1.35rem; }
    .moc-sections { padding: 0 1rem; }
    .section-grid { grid-template-columns: 1fr; }
    .ecosystem { padding: 0.5rem 1rem 1rem; }
    .eco-badge { font-size: 0.72rem; padding: 0.4rem 0.75rem; }
    .resources { padding: 0.5rem 1rem 1.5rem; }
    .resource-link { font-size: 0.78rem; padding: 0.4rem 0.75rem; }
    .landing-footer { padding: 1.5rem 1rem; }
  }
</style>

<script>
  document.getElementById('theme-toggle-landing')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Open search from landing
  document.getElementById('landing-search-btn')?.addEventListener('click', () => {
    document.getElementById('search-overlay')?.classList.add('open');
    (document.getElementById('search-input') as HTMLInputElement)?.focus();
  });
</script>
